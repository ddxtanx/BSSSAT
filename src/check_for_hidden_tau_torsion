import csv

classes_in_motivic = []
with open('Adams-motivic-E2-machine.csv', newline='') as csvfile:
    reader = csv.DictReader(csvfile)
    for row in reader:
        if int(row["stem"]) < 94 and int(row["Adams filtration"]) < 60 and int(row["weight"]) < 60:
            classes_in_motivic.append({"name": row['name'], "stem": int(row['stem']), "Adams filtration": int(row['Adams filtration']), "weight": int(row['weight']), "tautorsion": int(row['tautorsion'])})

def degree(element):
    return (element["stem"], element["Adams filtration"], element["weight"])

def add_degree(degree1, degree2):
    return (degree1[0] + degree2[0], degree1[1] + degree2[1], degree1[2] + degree2[2])


def sfdegree(element):
     return (element["stem"], element["Adams filtration"])

def tautorsion(element):
    return element["tautorsion"]

group_by_sf_with_tau_free = {}
for element in classes_in_motivic:
    if tautorsion(element) == 0:
        if sfdegree(element) not in group_by_sf_with_tau_free:
            group_by_sf_with_tau_free[sfdegree(element)] = [element]
        else:
            group_by_sf_with_tau_free[sfdegree(element)].append(element)

sf_list_with_tau_free = list(group_by_sf_with_tau_free.keys())

class_in_classical = []
with open('Adams-classical-E2.csv', newline='') as csvfile:
    reader = csv.DictReader(csvfile)
    for row in reader:
          if int(row["stem"]) < 94 and int(row["Adams filtration"]) < 60:
             class_in_classical.append({"name": row['name'], "stem": int(row['stem']), "Adams filtration": int(row['Adams filtration'])})

group_by_sf_classical = {}
for element in class_in_classical:
    if sfdegree(element) not in group_by_sf_classical:
        group_by_sf_classical[sfdegree(element)] = [element["name"]]
    else:
        group_by_sf_classical[sfdegree(element)].append(element["name"])

sf_list_classical = list(group_by_sf_classical.keys())

for element in sf_list_with_tau_free:
    if element not in sf_list_classical:
        print(f"Warning: The stem-filtration pair {element} is present in the motivic data but not in the classical data.")
for element in sf_list_classical:
    if element not in sf_list_with_tau_free:
        print(f"Warning: The stem-filtration pair {element} is present in the classical data but not in the motivic data.")


check_if_in_nice_world_1 = {}
for sf in sorted(set(sf_list_with_tau_free) | set(sf_list_classical)):
    motivic_classes = group_by_sf_with_tau_free.get(sf, [])
    classical_classes = group_by_sf_classical.get(sf, [])
    if len(motivic_classes) == len(classical_classes):
        continue
    if len(motivic_classes) != len(classical_classes):
        check_if_in_nice_world_1[sf] = {
            "motivic": [element["name"] for element in motivic_classes],
            "classical": classical_classes,
        }

for sf, data in check_if_in_nice_world_1.items():
    print(f"{sf}: {data}")

